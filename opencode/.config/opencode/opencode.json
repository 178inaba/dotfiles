      "git branch *": "allow",
      "git clone *": "allow",
      "git commit *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git mv *": "allow",
      "git pull": "allow",
